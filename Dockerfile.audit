FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl jq unzip file binutils && \
    rm -rf /var/lib/apt/lists/*

# Install graperoot and decompiler
RUN pip install --no-cache-dir graperoot==3.8.56 uncompyle6 decompile3 pycdc 2>/dev/null; \
    pip install --no-cache-dir graperoot==3.8.56

WORKDIR /audit

# Script to extract and inspect everything about graperoot
RUN cat > /audit/inspect.sh << 'SCRIPT'
#!/bin/bash
set -euo pipefail

echo "=========================================="
echo "  graperoot package audit"
echo "=========================================="
echo ""

# 1. Find where graperoot installed
SITE=$(python3 -c "import graperoot; import os; print(os.path.dirname(graperoot.__file__))")
echo "[1] Package location: $SITE"
echo ""

# 2. List all files
echo "[2] All files in package:"
find "$SITE" -type f | sort
echo ""

# 3. Show entry points (console_scripts)
echo "[3] Entry points (console_scripts):"
DIST=$(python3 -c "from importlib.metadata import distribution; d = distribution('graperoot'); print(d._path)")
cat "$DIST/METADATA" 2>/dev/null | head -30
echo "---"
cat "$DIST/entry_points.txt" 2>/dev/null || \
  python3 -c "from importlib.metadata import distribution; d = distribution('graperoot'); print(d.entry_points)" 2>/dev/null
echo ""

# 4. Show all .py source files
echo "[4] Python source files:"
find "$SITE" -name "*.py" -type f | while read f; do
  echo ""
  echo "===== $f ====="
  cat "$f"
done
echo ""

# 5. Check for compiled .so / .pyd files
echo "[5] Compiled extensions (.so/.pyd):"
find "$SITE" -name "*.so" -o -name "*.pyd" | sort
echo ""

# 6. Check for .pyc files and try to show them
echo "[6] Bytecode files (.pyc):"
find "$SITE" -name "*.pyc" -type f | sort
echo ""

# 7. Show package metadata
echo "[7] Full METADATA:"
cat "$DIST/METADATA" 2>/dev/null
echo ""

# 8. Show RECORD (all installed files with hashes)
echo "[8] RECORD:"
cat "$DIST/RECORD" 2>/dev/null
echo ""

# 9. Check what the entry point scripts actually contain
echo "[9] Entry point scripts:"
for cmd in graph-builder mcp-graph-server; do
  EP=$(which "$cmd" 2>/dev/null || echo "")
  if [ -n "$EP" ]; then
    echo "--- $cmd ($EP) ---"
    cat "$EP"
    echo ""
  fi
done

# 10. Try to decompile any .pyc files
echo "[10] Attempting .pyc decompilation:"
find "$SITE" -name "*.pyc" -type f | while read f; do
  echo ""
  echo "===== $f ====="
  python3 -c "
import dis, marshal, struct, time, sys
with open('$f', 'rb') as fp:
    magic = fp.read(4)
    flags = struct.unpack('<I', fp.read(4))[0]
    if flags & 0x1:  # PEP 552 hash-based
        fp.read(8)
    else:
        fp.read(8)  # timestamp + size
    code = marshal.loads(fp.read())
    dis.dis(code)
" 2>/dev/null | head -100 || echo "(decompilation failed)"
done

# 11. Network-related strings in all files
echo ""
echo "[11] Network-related strings (URLs, IPs, domains):"
find "$SITE" -type f | xargs strings 2>/dev/null | grep -iE '(https?://|railway|r2\.dev|cloudflare|analytics|telemetry|heartbeat|machine_id|identity|ping|webhook)' | sort -u
echo ""

# 12. Module imports and structure
echo "[12] Package __init__.py and module listing:"
python3 -c "
import graperoot
import pkgutil
print('Version:', getattr(graperoot, '__version__', 'unknown'))
print('Dir:', dir(graperoot))
for importer, modname, ispkg in pkgutil.walk_packages(graperoot.__path__, graperoot.__name__ + '.'):
    print(f'  {modname} (package={ispkg})')
"

SCRIPT

RUN chmod +x /audit/inspect.sh

CMD ["/audit/inspect.sh"]
