#!/usr/bin/env bash
# dgc — Dual-Graph launcher for Claude Code (fully local, no cloud)
#
# Usage:
#   dgc                          # scan current directory, start claude
#   dgc /path/to/project         # scan given project, start claude
#   dgc /path/to/project "task"  # scan and start with a prompt
#
# Setup (one time):
#   curl -sSL https://raw.githubusercontent.com/kunal12203/Codex-CLI-Compact/main/install.sh | bash
#   source ~/.zshrc

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$SCRIPT_DIR/venv"
PROJECT="${1:-$(pwd)}"
PROJECT="$(cd "$PROJECT" && pwd)"   # resolve to absolute
PROMPT="${2:-}"
MCP_PORT=8080
DATA_DIR="$PROJECT/.dual-graph"
PLIST="$HOME/Library/LaunchAgents/com.dual-graph.mcp.plist"

# ── Ensure venv + deps exist ──────────────────────────────────────────────────
if [[ ! -x "$VENV/bin/python3" ]]; then
  echo "[dgc] Creating venv at $VENV ..."
  python3 -m venv "$VENV"
  echo "[dgc] Installing Python dependencies..."
  "$VENV/bin/pip" install "mcp>=1.3.0" uvicorn anyio starlette --quiet
elif ! "$VENV/bin/python3" -c "import mcp, uvicorn, anyio, starlette" 2>/dev/null; then
  echo "[dgc] Installing missing Python dependencies..."
  "$VENV/bin/pip" install "mcp>=1.3.0" uvicorn anyio starlette --quiet
fi

PYTHON="$VENV/bin/python3"

echo "[dgc] Project : $PROJECT"
echo "[dgc] Data    : $DATA_DIR"
echo ""

mkdir -p "$DATA_DIR"

# Add .dual-graph to .gitignore (idempotent)
if [[ -f "$PROJECT/.gitignore" ]] && ! grep -qx '.dual-graph/' "$PROJECT/.gitignore" 2>/dev/null; then
  echo '.dual-graph/' >> "$PROJECT/.gitignore"
  echo "[dgc] Added .dual-graph/ to .gitignore"
fi

# ── Inject CLAUDE.md policy into project (idempotent) ────────────────────────
CLAUDE_MD="$PROJECT/CLAUDE.md"
if [[ ! -f "$CLAUDE_MD" ]]; then
  echo "[dgc] Creating CLAUDE.md ..."
  cat > "$CLAUDE_MD" << 'CLAUDE_EOF'
# Dual-Graph Context Policy

This project uses a local dual-graph MCP server for efficient context retrieval.

## MANDATORY: Always follow this order

1. **Call `graph_continue` first** — before any file exploration, grep, or code reading.

2. **If `graph_continue` returns `needs_project=true`**, call `graph_scan` with the
   current project directory (run `pwd` to get it). Do NOT ask the user.

3. **If `graph_continue` returns `mode=memory_first`**: use `graph_read` on `recommended_files` only.

4. **If `graph_continue` returns `mode=retrieve_then_read`**: use `graph_read` on `recommended_files`.

## Rules

- Do NOT use `rg`, `grep`, or bash file exploration before calling `graph_continue`.
- Do NOT dump full chat history.
- Do NOT call `graph_retrieve` more than once per turn.
- After edits, call `graph_register_edit` with the changed files.
CLAUDE_EOF
  echo "[dgc] CLAUDE.md created."
else
  echo "[dgc] CLAUDE.md already exists, skipping."
fi

# ── Scan project → local .dual-graph/info_graph.json ─────────────────────────
echo "[dgc] Scanning project..."
"$PYTHON" "$SCRIPT_DIR/graph_builder.py" --root "$PROJECT" --out "$DATA_DIR/info_graph.json"
echo "[dgc] Scan complete."
echo ""

# ── Register persistent launchd service (survives reboots) ───────────────────
mkdir -p "$HOME/Library/LaunchAgents"
cat > "$PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dual-graph.mcp</string>
    <key>ProgramArguments</key>
    <array>
        <string>$PYTHON</string>
        <string>$SCRIPT_DIR/mcp_graph_server.py</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>DG_DATA_DIR</key>
        <string>$DATA_DIR</string>
        <key>DUAL_GRAPH_PROJECT_ROOT</key>
        <string>$PROJECT</string>
        <key>DG_BASE_URL</key>
        <string>http://localhost:$MCP_PORT</string>
        <key>PORT</key>
        <string>$MCP_PORT</string>
    </dict>
    <key>StandardOutPath</key>
    <string>$DATA_DIR/mcp_server.log</string>
    <key>StandardErrorPath</key>
    <string>$DATA_DIR/mcp_server.log</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
PLIST_EOF

# Reload the service (stop old, start new with current project)
launchctl unload "$PLIST" 2>/dev/null || true
launchctl load "$PLIST"
echo "[dgc] MCP server registered as persistent service (auto-starts on login)."

# Wait for MCP server to be ready (up to 20s, TCP-level check)
echo "[dgc] Waiting for MCP server..."
for i in $(seq 1 20); do
  if nc -z localhost $MCP_PORT 2>/dev/null; then
    break
  fi
  sleep 1
done

echo "[dgc] MCP server ready on port $MCP_PORT."
echo ""

# ── Update claude MCP config ──────────────────────────────────────────────────
claude mcp remove dual-graph 2>/dev/null || true
claude mcp add --transport http dual-graph "http://localhost:$MCP_PORT/mcp"
echo "[dgc] MCP config updated → http://localhost:$MCP_PORT/mcp"
echo ""
echo "[dgc] Starting claude..."
echo ""

# ── Start Claude Code (server persists after claude exits) ───────────────────
cd "$PROJECT"
if [[ -n "$PROMPT" ]]; then
  claude "$PROMPT"
else
  claude
fi
